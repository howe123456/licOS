#!/usr/bin/env bash
#
# licOS Installer - Entry point script
#

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PYTHON="${PYTHON:-python3}"

if ! command -v "$PYTHON" &>/dev/null; then
    echo "Error: Python 3 is required but not found."
    echo "Install with: pacman -S python"
    exit 1
fi

# Check for psutil
if ! "$PYTHON" -c "import psutil" &>/dev/null; then
    echo "Installing required dependency: psutil..."
    if command -v pip &>/dev/null; then
        pip install psutil
    elif "$PYTHON" -m ensurepip &>/dev/null; then
        "$PYTHON" -m pip install psutil
    else
        echo "Error: psutil is required. Install with: pip install psutil"
        exit 1
    fi
fi

export PYTHONPATH="$SCRIPT_DIR:$PYTHONPATH"

echo "Starting licOS Installer..."
exec "$PYTHON" -m installer "$@"
