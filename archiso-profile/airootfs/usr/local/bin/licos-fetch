#!/bin/bash
# licOS Fetch v3.0 — System Information Tool
# Displays system info with lightning ASCII art
set -e

# ANSI colors
YELLOW='\033[1;33m'
CYAN='\033[1;36m'
WHITE='\033[1;37m'
DIM='\033[2;37m'
RESET='\033[0m'
BOLD='\033[1m'

# Collect system info
OS="Arch Linux"
[ -f /etc/os-release ] && OS=$(grep -oP 'PRETTY_NAME="\K[^"]+' /etc/os-release 2>/dev/null || echo "Arch Linux")
KERNEL=$(uname -r 2>/dev/null || echo "N/A")
HOSTNAME=$(uname -n 2>/dev/null || echo "N/A")
SHELL=$(basename "${SHELL:-unknown}" 2>/dev/null)
DE="${XDG_CURRENT_DESKTOP:-N/A}"
TERMINAL=$(basename "${TERM:-unknown}" 2>/dev/null)
CPU=$(grep -m1 'model name' /proc/cpuinfo 2>/dev/null | sed 's/.*: //' | sed 's/  */ /g' || echo "N/A")
CORES=$(nproc 2>/dev/null || echo "N/A")
RAM=$(free -h 2>/dev/null | awk '/Mem:/{print $3 "/" $2}' || echo "N/A")
DISK=$(df -h / 2>/dev/null | awk 'NR==2{print $3 "/" $2 " (" $5 ")"}' || echo "N/A")
UPTIME=$(uptime -p 2>/dev/null | sed 's/^up //' || echo "N/A")

# Print info
echo -e "${YELLOW}╔══════════════════════════════════════╗${RESET}"
echo -e "${YELLOW}║${RESET}    ${YELLOW}  \\   ${RESET}   ${WHITE}licOS v3.0${RESET}              ${YELLOW}║${RESET}"
echo -e "${YELLOW}║${RESET}     ${YELLOW}   X ${RESET}   ${DIM}──────────${RESET}              ${YELLOW}║${RESET}"
echo -e "${YELLOW}║${RESET}    ${YELLOW}  / ${RESET}   ${CYAN}OS:${RESET}     ${WHITE}${OS}${RESET}        ${YELLOW}║${RESET}"
echo -e "${YELLOW}║${RESET}           ${CYAN}Kernel:${RESET}  ${WHITE}${KERNEL}${RESET}      ${YELLOW}║${RESET}"
echo -e "${YELLOW}║${RESET}  ${YELLOW}═══╬═══${RESET}  ${CYAN}Host:${RESET}    ${WHITE}${HOSTNAME}${RESET}      ${YELLOW}║${RESET}"
echo -e "${YELLOW}║${RESET}  ${YELLOW}═══${RESET}     ${CYAN}DE:${RESET}      ${WHITE}${DE}${RESET}           ${YELLOW}║${RESET}"
echo -e "${YELLOW}║${RESET}           ${CYAN}Shell:${RESET}    ${WHITE}${SHELL}${RESET}          ${YELLOW}║${RESET}"
echo -e "${YELLOW}║${RESET}           ${CYAN}CPU:${RESET}     ${WHITE}${CPU:0:45}${RESET} ${YELLOW}║${RESET}"
echo -e "${YELLOW}║${RESET}           ${CYAN}Cores:${RESET}   ${WHITE}${CORES}${RESET}          ${YELLOW}║${RESET}"
echo -e "${YELLOW}║${RESET}           ${CYAN}RAM:${RESET}     ${WHITE}${RAM}${RESET}          ${YELLOW}║${RESET}"
echo -e "${YELLOW}║${RESET}           ${CYAN}Disk:${RESET}    ${WHITE}${DISK}${RESET}        ${YELLOW}║${RESET}"
echo -e "${YELLOW}║${RESET}           ${CYAN}Term:${RESET}    ${WHITE}${TERMINAL}${RESET}        ${YELLOW}║${RESET}"
echo -e "${YELLOW}║${RESET}           ${CYAN}Up:${RESET}      ${WHITE}${UPTIME}${RESET}          ${YELLOW}║${RESET}"
echo -e "${YELLOW}╚══════════════════════════════════════╝${RESET}"
